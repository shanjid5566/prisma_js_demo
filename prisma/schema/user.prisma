model User {
  id            String    @id @default(cuid())
  fullName      String
  email         String    @unique
  phoneNumber   String?
  password      String
  profileImage  String?
  role          Role      @default(USER) 
  
  // Relations
  listings      Listing[]
  payments      Payment[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum Role {
  USER
  ADMIN
}